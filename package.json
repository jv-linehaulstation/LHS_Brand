{
  "name": "lhs-homepage",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "LineHaul Station — primary landing page + 5 audience pages, built on the LHS Brand System.",
  "scripts": {
    "predev": "pkill -f 'next dev' 2>/dev/null || true; pkill -f next-server 2>/dev/null || true; sleep 1 || true",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "blog:seed": "node node_modules/payload/bin.js run scripts/seed-blog.ts",
    "payload": "node node_modules/payload/bin.js",
    "payload:types": "node node_modules/payload/bin.js generate:types",
    "payload:migrate": "node node_modules/payload/bin.js migrate"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.85.2",
    "@payloadcms/next": "^3.85.2",
    "@payloadcms/richtext-lexical": "^3.85.2",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "graphql": "^16.14.2",
    "lenis": "^1.3.23",
    "next": "~15.4.11",
    "payload": "^3.85.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "10.4.19",
    "playwright": "^1.61.1",
    "postcss": "8.4.39",
    "tailwindcss": "3.4.6",
    "tsx": "^4.22.4",
    "typescript": "5.5.3"
  }
}
