# Copy to `.env.local` and fill in. Restart `npm run dev` after editing.

# --- Payload CMS (Blog) ---
# The blog now runs on Payload (admin at /admin), stored in your Supabase
# Postgres via the Postgres adapter (in its own `payload` schema).

# Signing secret for Payload sessions/JWT. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=your-random-64-char-hex-secret

# Supabase Postgres connection string. Get it from the Supabase dashboard:
#   Settings → Database → Connect → Session pooler → copy URI.
# Replace [YOUR-DB-PASSWORD] and the <region>.
DATABASE_URI=postgresql://postgres.YOUR-PROJECT-REF:[YOUR-DB-PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres

# Optional — create the first admin user automatically during `npm run blog:seed`.
# If unset, create it via the /admin "first user" screen instead.
# SEED_ADMIN_EMAIL=you@example.com
# SEED_ADMIN_PASSWORD=a-strong-password

# --- Supabase JS (legacy) ---
# Still present for the public project URL/anon key. The blog no longer reads
# posts through these (Payload owns the blog now); safe to keep or remove.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# --- GoHighLevel ---
# Inbound webhook where lead-form + Outriders join submissions POST.
# Safe to expose (browser fetch). Leave unset and forms still succeed silently.
NEXT_PUBLIC_GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/YOUR-WEBHOOK-ID
