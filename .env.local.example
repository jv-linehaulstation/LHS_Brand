# Supabase — copy to `.env.local` and fill in from your project's
# Settings → API page. Restart `npm run dev` after editing.

# Safe to expose to the browser:
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — used by `npm run blog:seed`. NEVER prefix with NEXT_PUBLIC and
# never commit the real value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# GoHighLevel inbound webhook — where lead-form + Outriders join submissions POST.
# Safe to expose (it's a browser fetch). Leave unset and the forms still succeed
# gracefully (they just don't forward anywhere). Paste your GHL inbound webhook URL.
NEXT_PUBLIC_GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/YOUR-WEBHOOK-ID
